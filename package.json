{
  "name": "@gelato-ui/theme",
  "version": "0.1.0",
  "description": "Web Components UI library",
  "type": "module",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "dev": "npm run build -- --watch ./src",
    "build": "tsup src/index.ts --format esm --dts",
    "build:dev": "tsup --watch",
    "build:prod": "rm -rf ./dist && env NODE_ENV=production tsup",
    "build:watch": "tsup --watch",
    "inspector": "npx @eslint/config-inspector@latest",
    "lint": "eslint . --report-unused-disable-directives",
    "lint:fix": "npm run lint -- --fix --max-warnings=0",
    "pre-commit": "lint-staged && npm run test",
    "pre-push": "npm run build && npm run lint:fix",
    "prepare": "husky config/.husky",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/gelato-ui.git"
  },
  "bugs": {
    "url": "https://github.com/santi020k/gelato-ui/issues"
  },
  "homepage": "https://github.com/santi020k/gelato-ui#readme",
  "keywords": [
    "eslint",
    "config",
    "santi020k",
    "gelato-ui"
  ],
  "author": "santi020k",
  "contributors": [
    "Santiago Molina <info@santi020k.me>"
  ],
  "license": "Apache License 2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^18.18.0 || ^20.9.0 || >=21.1.0"
  },
  "devDependencies": {
    "@santi020k/eslint-config-santi020k": "^3.0.0",
    "@types/node": "^22.7.5",
    "cz-conventional-changelog": "^3.3.0",
    "happy-dom": "^15.7.4",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2",
    "tsup": "^8.3.0"
  },
  "lint-staged": {
    "*.{js, jsx, ts, tsx, md}": [
      "npm run lint:fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
