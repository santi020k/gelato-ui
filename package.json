{
  "name": "@santi020k/gelato-ui",
  "version": "0.1.0",
  "description": "Web Components UI library",
  "type": "module",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "build:clean": "rm -rf dist",
    "build": "rollup --config rollup.config.js && rollup --config rollup.config.es.js",
    "dev": "rollup --config rollup.config.js --watch",
    "inspector": "npx @eslint/config-inspector@latest",
    "lint": "eslint . --report-unused-disable-directives",
    "lint:fix": "npm run lint -- --fix --max-warnings=0",
    "pre-commit": "lint-staged",
    "pre-push": "npm run build && npm run lint:fix",
    "prepare": "husky config/.husky",
    "test": "not yet"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santi020k/gelato-ui.git"
  },
  "bugs": {
    "url": "https://github.com/santi020k/gelato-ui/issues"
  },
  "homepage": "https://github.com/santi020k/gelato-ui#readme",
  "keywords": [
    "eslint",
    "config",
    "santi020k",
    "gelato-ui"
  ],
  "author": "santi020k",
  "contributors": [
    "Santiago Molina <info@santi020k.me>"
  ],
  "license": "Apache License 2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^18.18.0 || ^20.9.0 || >=21.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@santi020k/eslint-config-santi020k": "^2.1.0",
    "@types/node": "^22.1.0",
    "@types/rollup-plugin-generate-package-json": "^3.2.9",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.23.0",
    "husky": "^9.1.4",
    "i": "^0.3.7",
    "lint-staged": "^15.2.7",
    "npm": "^10.8.2",
    "rollup": "^4.19.2",
    "rollup-plugin-generate-package-json": "^3.2.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "tslib": "^2.6.3",
    "typescript": "^5.5.4"
  },
  "lint-staged": {
    "*.{js, jsx, ts, tsx, md}": [
      "npm run lint:fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
